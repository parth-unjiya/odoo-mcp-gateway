# ──────────────────────────────────────────────────────────────────
# odoo-mcp-gateway configuration
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────

# ── Odoo Connection ──────────────────────────────────────────────
# Base URL of the Odoo instance (http or https only)
ODOO_URL=http://localhost:8069

# Database name (alphanumeric, underscore, hyphen, dot only)
ODOO_DB=

# Optional: Odoo username for env-var-based authentication
ODOO_USERNAME=

# Optional: Odoo API key for env-var-based authentication
ODOO_API_KEY=

# ── MCP Transport ───────────────────────────────────────────────
# Transport mode: "stdio" (default) or "streamable-http"
MCP_TRANSPORT=stdio

# Host to bind when using streamable-http transport
MCP_HOST=127.0.0.1

# Port to bind when using streamable-http transport
MCP_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
MCP_LOG_LEVEL=INFO

# ── YAML Config ─────────────────────────────────────────────────
# Directory containing YAML configuration files (gateway.yaml, etc.)
CONFIG_DIR=.

# ── Performance / Limits ────────────────────────────────────────
# How long to cache metadata (model fields, etc.) in seconds
CACHE_TTL_SECONDS=3600

# Maximum number of concurrent MCP sessions
MAX_CONCURRENT_SESSIONS=100

# Idle session timeout in seconds
SESSION_TIMEOUT_SECONDS=1800

# ── Rate Limiting ───────────────────────────────────────────────
# Maximum requests per minute (global, all operations)
RATE_LIMIT_GLOBAL=60

# Maximum write operations (create/update/delete) per minute
RATE_LIMIT_WRITE=20
